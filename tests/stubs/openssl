#!/usr/bin/env bash
#======================================================================
# STUB       : tests/stubs/openssl
#======================================================================
# Synopsis   : Mock openssl binary for BATS testing.
#
# Description: Replaces the real openssl in PATH during tests. The
#              script calls openssl for self-signed certificate
#              generation in tunnel mode. This stub:
#
#              1. Parses the -keyout and -out arguments to determine
#                 where to write the dummy files
#              2. Creates placeholder cert and key files at those paths
#              3. Sets appropriate permissions (644 for cert, 600 for key)
#              4. Logs the invocation for test verification
#
#              The generated files are not real certificates — they
#              contain placeholder text. This is sufficient for testing
#              because the stub socat never performs a real TLS handshake.
#
# Environment:
#   TEST_TMPDIR - Temp directory for this test (set by test_helper)
#
# Notes      : - This file must be executable (chmod +x)
#              - Only handles the `req -x509` subcommand used by
#                generate_self_signed_cert()
#              - For `openssl version`, returns a mock version string
#
# Version    : 1.0.0
#======================================================================

STUB_LOG="${TEST_TMPDIR:-.}/.openssl_stub.log"

# Log the invocation
echo "[$(date '+%Y-%m-%dT%H:%M:%S')] PID=$$ ARGS=$*" >> "${STUB_LOG}" 2>/dev/null || true

# Handle 'openssl version' (used by dependency checks)
if [[ "${1:-}" == "version" ]]; then
    echo "OpenSSL 3.0.0 (stub) 7 Sep 2021"
    exit 0
fi

# Handle 'openssl req -x509 ...' (certificate generation)
if [[ "${1:-}" == "req" ]]; then
    # Parse -keyout and -out arguments
    local key_file="" cert_file=""
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -keyout) key_file="${2}"; shift 2 ;;
            -out)    cert_file="${2}"; shift 2 ;;
            *)       shift ;;
        esac
    done

    # Create dummy certificate file
    if [[ -n "${cert_file}" ]]; then
        cat > "${cert_file}" << 'CERTEOF'
-----BEGIN CERTIFICATE-----
STUB_CERTIFICATE_FOR_TESTING_ONLY
This is not a real certificate.
Generated by tests/stubs/openssl
-----END CERTIFICATE-----
CERTEOF
        chmod 644 "${cert_file}" 2>/dev/null || true
    fi

    # Create dummy private key file
    if [[ -n "${key_file}" ]]; then
        cat > "${key_file}" << 'KEYEOF'
-----BEGIN PRIVATE KEY-----
STUB_PRIVATE_KEY_FOR_TESTING_ONLY
This is not a real private key.
Generated by tests/stubs/openssl
-----END PRIVATE KEY-----
KEYEOF
        chmod 600 "${key_file}" 2>/dev/null || true
    fi

    exit 0
fi

# Unknown subcommand — exit success by default
exit 0
